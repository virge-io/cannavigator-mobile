    "expo": "54.0.34",
    "expo-constants": "18.0.13",
    "expo-linking": "8.0.12",
    "expo-router": "6.0.23",
    "expo-status-bar": "3.0.9",
    "expo-system-ui": "6.0.9",
    "lucide-react-native": "^1.7.0",
    "react": "19.1.0",
